# Copy this file to `.env` and fill in your real values.
# The `.env` is gitignored; this example is committed so newcomers know
# exactly which variables the pipeline reads.

# ---- Database ----
DB_HOST=localhost
DB_PORT=56432
DB_NAME=rag
DB_USER=rag
DB_PASSWORD=**********
CHUNKS_TABLE=chunks

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text-v2-moe

# ---- Pre-pipeline safety guard ----
# Pull once:  ollama pull llama-guard3:1b
# GUARD_ENABLED=false  ->  skip the guard entirely (no Ollama call)
GUARD_MODEL=llama-guard3:1b
GUARD_ENABLED=true

# ---- Cross-encoder reranker ----
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATES=20
RERANK_TOP_N=5

# ---- Generator (Ollama LLM) ----
GEN_MODEL=minimax-m3:cloud
GEN_TEMPERATURE=0.2
GEN_MAX_TOKENS=400

# ---- RAGAS judge LLM (must be a different model from GEN_MODEL) ----
JUDGE_MODEL=gemma4:e2b
JUDGE_TEMPERATURE=0.0
