# Root .gitignore -- see also rag/.gitignore for project-internal exclusions
# (this file lives at the working-tree root because git only honors
# .gitignore files at or above the path being checked).

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- Virtualenv ---
.venv/
venv/
env/
.env.bak

# --- Secrets / private config ---
.env
*.pem
*.key

# --- Corpus + ephemeral data ---
website-main/
data/
*.csv

# --- Generated artifacts ---
*.png
*.log
*.sqlite
*.sqlite3

# --- Editor noise ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Stray files from shell mishaps ---
.venvScriptspython.exe
*PYTHONPATH

# --- Ad-hoc scripts (one-shot experiments) ---
check_chunks.py
visualize_chunking.py

# --- Personal writing aids ---
humanizer.md
writter.md
